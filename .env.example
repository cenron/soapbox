# soapbox — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# App
APP_ENV=development

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Database (Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=soapbox
DB_USER=soapbox
DB_PASSWORD=soapbox
DB_SSLMODE=disable

# S3 (MinIO for dev)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=soapbox
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Mail (Mailpit for dev)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=noreply@soapbox.dev

# JWT
JWT_SECRET=dev-secret-change-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
